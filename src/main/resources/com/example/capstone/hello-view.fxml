<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.capstone.controller.MainController"
            stylesheets="@theme.css"
            style="-fx-background-color: #FFFDF8;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #7A1E2C; -fx-padding: 14 22; -fx-border-color: #D4A017; -fx-border-width: 0 0 2 0;">
            <Label text="CoreStock"
                   style="-fx-text-fill: #F6D36B; -fx-font-size: 22; -fx-font-weight: bold;"/>
            <Label text="Smart Inventory Management"
                   style="-fx-text-fill: #FFFDF8; -fx-font-size: 13;"/>
            <Label text="|" style="-fx-text-fill: #D4A017;"/>
            <Label fx:id="companyLabel" text="Company"
                   style="-fx-text-fill: #FFFFFF; -fx-font-size: 13; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="roleLabel" text="Admin Access"
                   style="-fx-text-fill: #F6E9C8; -fx-font-size: 12;"/>
            <Button fx:id="reportButton" text="Generate Report" onAction="#onGenerateReport"
                    style="-fx-background-color: #D4A017; -fx-text-fill: #2B1B1F; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 14;"/>
            <Button text="Logout" onAction="#onLogout"
                    style="-fx-background-color: transparent; -fx-text-fill: #FFFDF8; -fx-border-color: #D4A017; -fx-border-radius: 8; -fx-padding: 8 14;"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="6"
              style="-fx-background-color: #7A1E2C; -fx-padding: 18 12; -fx-min-width: 190; -fx-border-color: #D4A017; -fx-border-width: 0 2 0 0;">
            <Label text="MENU" style="-fx-text-fill: #F6D36B; -fx-font-size: 11; -fx-font-weight: bold; -fx-padding: 0 0 8 8;"/>
            <Button fx:id="navProducts" text="Products" maxWidth="Infinity" onAction="#showProducts"/>
            <Button fx:id="navLowStock" text="Low Stock Alerts" maxWidth="Infinity" onAction="#showLowStock"/>
            <Button fx:id="navSales" text="Sales / Sold Items" maxWidth="Infinity" onAction="#showSales"/>
            <Button fx:id="navLogs" text="Inventory Logs" maxWidth="Infinity" onAction="#showLogs"/>
            <Button fx:id="navCategories" text="Categories" maxWidth="Infinity" onAction="#showCategories"/>
            <Button fx:id="navSuppliers" text="Suppliers" maxWidth="Infinity" onAction="#showSuppliers"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button fx:id="navProfile" text="Edit Profile" maxWidth="Infinity" onAction="#showProfile"/>
        </VBox>
    </left>

    <center>
        <StackPane style="-fx-padding: 22;">
            <VBox fx:id="productsPane" spacing="16">
                <HBox alignment="CENTER_LEFT" spacing="12">
                    <VBox spacing="2">
                        <Label text="Products" style="-fx-text-fill: #2B1B1F; -fx-font-size: 24; -fx-font-weight: bold;"/>
                        <Label text="Search, filter, view inventory, and manage stock." style="-fx-text-fill: #6F5A5D;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="searchField" promptText="Search products" prefWidth="220"/>
                    <ComboBox fx:id="filterCategoryCombo" promptText="Category" prefWidth="160"/>
                    <ComboBox fx:id="stockFilterCombo" prefWidth="145"/>
                    <Button text="Clear" onAction="#onClearFilters"/>
                </HBox>

                <HBox spacing="12">
                    <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-padding: 14; -fx-background-radius: 8; -fx-border-color: rgba(122,30,44,0.18); -fx-border-radius: 8;">
                        <Label text="TOTAL SKUS" style="-fx-text-fill: #6F5A5D; -fx-font-size: 10;"/>
                        <Label fx:id="statSkuLabel" text="0" style="-fx-text-fill: #2B1B1F; -fx-font-size: 24; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-padding: 14; -fx-background-radius: 8; -fx-border-color: rgba(122,30,44,0.18); -fx-border-radius: 8;">
                        <Label text="TOTAL VALUE" style="-fx-text-fill: #6F5A5D; -fx-font-size: 10;"/>
                        <Label fx:id="statValueLabel" text="P 0.00" style="-fx-text-fill: #7A1E2C; -fx-font-size: 24; -fx-font-weight: bold;"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: #FFFFFF; -fx-padding: 14; -fx-background-radius: 8; -fx-border-color: rgba(122,30,44,0.18); -fx-border-radius: 8;">
                        <Label text="LOW STOCK" style="-fx-text-fill: #6F5A5D; -fx-font-size: 10;"/>
                        <Label fx:id="statLowLabel" text="0" style="-fx-text-fill: #D4A017; -fx-font-size: 24; -fx-font-weight: bold;"/>
                    </VBox>
                </HBox>

                <TableView fx:id="productTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="55"/>
                        <TableColumn fx:id="nameColumn" text="Name" prefWidth="190"/>
                        <TableColumn fx:id="categoryColumn" text="Category" prefWidth="140"/>
                        <TableColumn fx:id="supplierColumn" text="Supplier" prefWidth="150"/>
                        <TableColumn fx:id="priceColumn" text="Price" prefWidth="90"/>
                        <TableColumn fx:id="qtyColumn" text="Qty" prefWidth="70"/>
                    </columns>
                </TableView>

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Button fx:id="addProductButton" text="Add Product" onAction="#onAddProduct"/>
                    <Button fx:id="editProductButton" text="Edit" onAction="#onEditProduct"/>
                    <Button fx:id="deleteProductButton" text="Delete" onAction="#onDeleteProduct"/>
                    <Label fx:id="selectedStockLabel" text="Selected Stock: --" style="-fx-text-fill: #6F5A5D; -fx-padding: 0 10;"/>
                    <TextField fx:id="stockAmountField" promptText="Amount" prefWidth="80"/>
                    <Button fx:id="decreaseStockButton" text="- Stock" onAction="#onDecreaseStock"/>
                    <Button fx:id="increaseStockButton" text="+ Stock" onAction="#onIncreaseStock"/>
                </HBox>
            </VBox>

            <VBox fx:id="lowStockPane" spacing="16" visible="false" managed="false">
                <Label text="Low Stock Alerts" style="-fx-text-fill: #2B1B1F; -fx-font-size: 24; -fx-font-weight: bold;"/>
                <TableView fx:id="lowStockTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="lowIdColumn" text="ID" prefWidth="70"/>
                        <TableColumn fx:id="lowNameColumn" text="Product" prefWidth="240"/>
                        <TableColumn fx:id="lowCategoryColumn" text="Category" prefWidth="180"/>
                        <TableColumn fx:id="lowQtyColumn" text="Qty" prefWidth="100"/>
                        <TableColumn fx:id="lowThresholdColumn" text="Alert Level" prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox fx:id="salesPane" spacing="16" visible="false" managed="false">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="Sales / Sold Items" style="-fx-text-fill: #2B1B1F; -fx-font-size: 24; -fx-font-weight: bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="saleProductCombo" promptText="Product" prefWidth="220"/>
                    <TextField fx:id="saleQuantityField" promptText="Qty" prefWidth="70"/>
                    <TextField fx:id="saleNoteField" promptText="Note" prefWidth="170"/>
                    <Label fx:id="saleTotalLabel" text="Total: P 0.00" style="-fx-text-fill: #7A1E2C; -fx-font-weight: bold;"/>
                    <Button text="Record Sale" onAction="#onRecordSale"/>
                </HBox>
                <TableView fx:id="salesTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="saleIdColumn" text="Sale ID" prefWidth="75"/>
                        <TableColumn fx:id="saleProductColumn" text="Product" prefWidth="220"/>
                        <TableColumn fx:id="saleQtyColumn" text="Qty" prefWidth="70"/>
                        <TableColumn fx:id="saleUnitColumn" text="Unit Price" prefWidth="100"/>
                        <TableColumn fx:id="saleSubtotalColumn" text="Subtotal" prefWidth="100"/>
                        <TableColumn fx:id="saleDateColumn" text="Date" prefWidth="160"/>
                        <TableColumn fx:id="saleUserColumn" text="Recorded By" prefWidth="150"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox fx:id="logsPane" spacing="16" visible="false" managed="false">
                <Label text="Inventory Logs" style="-fx-text-fill: #2B1B1F; -fx-font-size: 24; -fx-font-weight: bold;"/>
                <TableView fx:id="logsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="logIdColumn" text="Log ID" prefWidth="70"/>
                        <TableColumn fx:id="logProductColumn" text="Product" prefWidth="170"/>
                        <TableColumn fx:id="logUserColumn" text="User" prefWidth="120"/>
                        <TableColumn fx:id="logTypeColumn" text="Type" prefWidth="85"/>
                        <TableColumn fx:id="logBeforeColumn" text="Before" prefWidth="75"/>
                        <TableColumn fx:id="logChangeColumn" text="Change" prefWidth="75"/>
                        <TableColumn fx:id="logAfterColumn" text="After" prefWidth="75"/>
                        <TableColumn fx:id="logNoteColumn" text="Note" prefWidth="210"/>
                        <TableColumn fx:id="logDateColumn" text="Logged At" prefWidth="160"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox fx:id="categoriesPane" spacing="16" visible="false" managed="false">
                <Label text="Categories" style="-fx-text-fill: #2B1B1F; -fx-font-size: 24; -fx-font-weight: bold;"/>
                <TableView fx:id="categoryTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="catIdColumn" text="ID" prefWidth="70"/>
                        <TableColumn fx:id="catNameColumn" text="Name" prefWidth="220"/>
                        <TableColumn fx:id="catDescColumn" text="Description" prefWidth="420"/>
                    </columns>
                </TableView>
                <HBox spacing="8">
                    <Button text="Add" onAction="#onAddCategory"/>
                    <Button text="Edit" onAction="#onEditCategory"/>
                    <Button text="Delete" onAction="#onDeleteCategory"/>
                </HBox>
            </VBox>

            <VBox fx:id="suppliersPane" spacing="16" visible="false" managed="false">
                <Label text="Suppliers" style="-fx-text-fill: #2B1B1F; -fx-font-size: 24; -fx-font-weight: bold;"/>
                <TableView fx:id="supplierTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="supIdColumn" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="supNameColumn" text="Name" prefWidth="180"/>
                        <TableColumn fx:id="supContactColumn" text="Contact" prefWidth="160"/>
                        <TableColumn fx:id="supPhoneColumn" text="Phone" prefWidth="130"/>
                        <TableColumn fx:id="supEmailColumn" text="Email" prefWidth="190"/>
                        <TableColumn fx:id="supAddressColumn" text="Address" prefWidth="220"/>
                    </columns>
                </TableView>
                <HBox spacing="8">
                    <Button text="Add" onAction="#onAddSupplier"/>
                    <Button text="Edit" onAction="#onEditSupplier"/>
                    <Button text="Delete" onAction="#onDeleteSupplier"/>
                </HBox>
            </VBox>

            <VBox fx:id="profilePane" spacing="14" visible="false" managed="false" maxWidth="520" StackPane.alignment="TOP_LEFT">
                <Label text="Edit Profile" style="-fx-text-fill: #2B1B1F; -fx-font-size: 24; -fx-font-weight: bold;"/>
                <Label text="Full Name" style="-fx-text-fill: #6F5A5D;"/>
                <TextField fx:id="profileNameField"/>
                <Label text="Company Name" style="-fx-text-fill: #6F5A5D;"/>
                <TextField fx:id="profileCompanyField"/>
                <Label text="Email" style="-fx-text-fill: #6F5A5D;"/>
                <TextField fx:id="profileEmailField"/>
                <Label text="Username" style="-fx-text-fill: #6F5A5D;"/>
                <TextField fx:id="profileUsernameField"/>
                <Label text="Password" style="-fx-text-fill: #6F5A5D;"/>
                <TextField fx:id="profilePasswordField" promptText="Leave blank to keep current password"/>
                <HBox spacing="8">
                    <Label text="Role:" style="-fx-text-fill: #6F5A5D;"/>
                    <Label fx:id="profileRoleLabel" text="admin" style="-fx-text-fill: #7A1E2C; -fx-font-weight: bold;"/>
                </HBox>
                <Button text="Save Profile" onAction="#onSaveProfile"/>
                <Button text="Delete Account" onAction="#onDeleteAccount"
                        style="-fx-background-color: transparent; -fx-text-fill: #B42318; -fx-border-color: rgba(180,35,24,0.35); -fx-border-radius: 8; -fx-padding: 10 14;"/>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
