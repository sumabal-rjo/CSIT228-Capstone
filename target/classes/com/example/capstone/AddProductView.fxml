<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="14"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.capstone.controller.AddProductController"
      style="-fx-background-color: #0F1A26; -fx-padding: 28; -fx-min-width: 440;">

    <Label text="Add / Edit Product"
           style="-fx-text-fill: #F5F7FA; -fx-font-size: 24; -fx-font-weight: bold;"/>
    <Label text="Product Details"
           style="-fx-text-fill: #6EE7B7; -fx-font-size: 12; -fx-font-weight: bold;"/>

    <Label text="Product Name" style="-fx-text-fill: #8FA3B8;"/>
    <TextField fx:id="nameField" promptText="Example: Wireless Headphones"/>

    <Label text="Description" style="-fx-text-fill: #8FA3B8;"/>
    <TextField fx:id="descField" promptText="Short product description"/>

    <GridPane hgap="12" vgap="8">
        <columnConstraints>
            <ColumnConstraints percentWidth="50"/>
            <ColumnConstraints percentWidth="50"/>
        </columnConstraints>

        <Label text="Category" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #8FA3B8;"/>
        <Label text="Supplier" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-text-fill: #8FA3B8;"/>
        <ComboBox fx:id="categoryCombo" promptText="Select category" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <ComboBox fx:id="supplierCombo" promptText="Select supplier" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    </GridPane>

    <GridPane hgap="12" vgap="8">
        <columnConstraints>
            <ColumnConstraints percentWidth="34"/>
            <ColumnConstraints percentWidth="33"/>
            <ColumnConstraints percentWidth="33"/>
        </columnConstraints>

        <Label text="Price" GridPane.columnIndex="0" GridPane.rowIndex="0" style="-fx-text-fill: #8FA3B8;"/>
        <Label text="Quantity" GridPane.columnIndex="1" GridPane.rowIndex="0" style="-fx-text-fill: #8FA3B8;"/>
        <Label text="Alert Level" GridPane.columnIndex="2" GridPane.rowIndex="0" style="-fx-text-fill: #8FA3B8;"/>
        <TextField fx:id="priceField" promptText="0.00" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="quantityField" promptText="0" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <TextField fx:id="thresholdField" promptText="10" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
    </GridPane>

    <HBox spacing="10" style="-fx-padding: 12 0 0 0;">
        <Button text="Save Product" onAction="#onSave" maxWidth="Infinity" HBox.hgrow="ALWAYS"
                style="-fx-background-color: #6EE7B7; -fx-text-fill: #062016; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 18;"/>
        <Button text="Cancel" onAction="#onCancel"
                style="-fx-background-color: transparent; -fx-text-fill: #D9E6F2; -fx-border-color: #314256; -fx-border-radius: 8; -fx-padding: 10 18;"/>
    </HBox>
</VBox>
